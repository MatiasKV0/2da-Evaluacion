@startuml TRACEX_Secuencia_SolicitarEnvio

skinparam sequence {
  ArrowColor #1A56A0
  ActorBorderColor #1A56A0
  ActorBackgroundColor #D5E8D4
  ParticipantBorderColor #1A56A0
  ParticipantBackgroundColor #EEF5FF
  ParticipantFontSize 13
  LifeLineBorderColor #A0B4CC
  BoxBackgroundColor #F8FAFF
  BoxBorderColor #D1DCE8
}

skinparam NoteBorderColor #F0D080
skinparam NoteBackgroundColor #FFFBF0

title TRACEX — Diagrama de Secuencia: Solicitar Envío (Flujo Principal)

actor "Cliente /\nRemitente" as Cliente

box "Sistema TRACEX" #F0F4F8
  participant "SolicitarEnvioController" as Ctrl   <<Controlador GRASP>>
  participant "Envio"                    as Envio  <<Experto / Creador>>
  participant "CalculadorImporte"        as Calc   <<Experto GRASP>>
  participant "SistemaPago"             as Pago   <<Fabricación Pura>>
  participant "GeneradorSeguimiento"    as Gen    <<Fabricación Pura>>
end box

participant "Pasarela de Pago\n(externo)" as PagoExt <<system>>

== Paso 1: Ingreso de datos del destinatario y paquete ==

Cliente -> Ctrl : solicitarEnvio(datosDestinatario, datosPaquete, tipoServicio)
activate Ctrl

Ctrl -> Ctrl : validarDatos(datosDestinatario, datosPaquete)
note right of Ctrl
  **GRASP Controlador**
  Recibe y coordina el evento
  del sistema disparado por
  el actor externo (Cliente).
end note

== Paso 2: Cálculo del importe ==

Ctrl -> Calc : calcularImporte(datosPaquete, tipoServicio, zonaDestino)
activate Calc
note right of Calc
  **GRASP Experto**
  Tiene la información necesaria
  (tarifas, zonas, pesos) para
  calcular el importe.
end note
Calc --> Ctrl : importeTotal
deactivate Calc

Ctrl --> Cliente : mostrarResumen(datosEnvio, importeTotal)

== Paso 3: Confirmación y pago ==

Cliente -> Ctrl : confirmarYPagar(datosPago)
activate Ctrl

Ctrl -> Pago : procesarPago(datosPago, importeTotal)
activate Pago
note right of Pago
  **GRASP Fabricación Pura**
  Clase artificial que encapsula
  la lógica de integración con
  la pasarela externa, manteniendo
  bajo acoplamiento.
end note

Pago -> PagoExt : ejecutarTransaccion(datosPago, importeTotal)
activate PagoExt
PagoExt --> Pago : respuestaPago (aprobado)
deactivate PagoExt

Pago --> Ctrl : pagoConfirmado
deactivate Pago

== Paso 4: Creación del envío y generación del código ==

Ctrl -> Envio : crear(datosDestinatario, datosPaquete, tipoServicio, importeTotal)
activate Envio
note right of Envio
  **GRASP Creador**
  El Controlador crea la instancia
  de Envio ya que lo registra,
  contiene y usa directamente.
end note
Envio --> Ctrl : instanciaEnvio
deactivate Envio

Ctrl -> Gen : generarCodigoSeguimiento(instanciaEnvio)
activate Gen
note right of Gen
  **GRASP Fabricación Pura**
  Responsabilidad técnica de generar
  códigos únicos y etiquetas PDF,
  separada del dominio de negocio.
end note
Gen --> Ctrl : codigoSeguimiento, etiquetaPDF
deactivate Gen

Ctrl --> Cliente : mostrarConfirmacion(codigoSeguimiento, etiquetaPDF)
deactivate Ctrl

@enduml